{
  "name": "ieee-atiig-accessibility-menu",
  "version": "1.0.1",
  "description": "A fully customizable React accessibility menu component with font scaling, reading aids, color adjustments, and more.",
  "keywords": [
    "accessibility",
    "a11y",
    "menu",
    "react",
    "component",
    "wcag",
    "font-size",
    "reading-aid",
    "dyslexia",
    "grayscale"
  ],
  "license": "MIT",
  "author": {
    "name": "Shayen71421",
    "url": "https://github.com/shayen71421"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shayen71421/ieee-atiig-accessibility-menu.git"
  },
  "bugs": {
    "url": "https://github.com/shayen71421/ieee-atiig-accessibility-menu/issues"
  },
  "homepage": "https://github.com/shayen71421/ieee-atiig-accessibility-menu#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles.css": {
      "import": "./dist/styles.css",
      "require": "./dist/styles.css"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "build:dev": "tsup --no-minify",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "postbuild": "node scripts/postbuild.mjs",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "release": "npm run build && npm publish",
    "release:dry": "npm run build && npm publish --dry-run"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "motion-utils": "^12.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
